# Supabase (obtenlas en: app.supabase.com → Settings → API)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...  # anon/public key

# ─── Para las Edge Functions (se configuran en Supabase, NO en Vercel) ───
# Supabase Dashboard → Edge Functions → Secrets
#   GEMINI_API_KEY=AIza...   ← obtenla gratis en https://aistudio.google.com
